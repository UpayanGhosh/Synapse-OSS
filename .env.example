# .env.example
# Synapse OSS Environment Configuration Template
# Copy this file to .env and fill in your values:
#   Mac/Linux: cp .env.example .env
#   Windows:   copy .env.example .env

# --- LLM Provider API Keys ---
# Google Gemini (Primary brain — REQUIRED)
GEMINI_API_KEY="your_gemini_api_key_here"

# OpenRouter (Fallback / Backup Models)
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# OpenAI / Custom (For specific tools or overrides)
OPENAI_API_KEY="your_openai_api_key_here"

# Groq (Required for voice message transcription via Groq Whisper)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY="your_groq_api_key_here"

# Cohere (Optional — for Cohere Command models)
# Get your key at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY="your_cohere_api_key_here"

# --- Infrastructure Config ---
# (OPTIONAL) IP address of the local PC running Ollama inference (The Vault)
# If you leave this blank, the system runs entirely on Cloud API keys.
WINDOWS_PC_IP=""

# --- Security & Webhooks ---
# WhatsApp Bridge authorization secret
WHATSAPP_BRIDGE_TOKEN="your_whatsapp_bridge_secret"

# Gateway WebSocket authentication (optional)
# SYNAPSE_GATEWAY_TOKEN=

# --- User Identity ---
# Your phone number (E.164 format, e.g. +15551234567) — used for admin-level access
ADMIN_PHONE=""
# Optional: VIP user phone number (gets elevated access to tools like Gmail/Calendar)
VIP_PHONE=""

# --- Operational Settings ---
# Default session type for memory routing ("safe" or "spicy")
SESSION_TYPE="safe"
