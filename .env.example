# .env.example
# Synapse OSS Environment Configuration Template
# Copy this file to .env and fill in the values you need:
#   Mac/Linux: cp .env.example .env
#   Windows:   copy .env.example .env
#
# Only fill in the providers you actually plan to use.
# All keys below are OPTIONAL unless explicitly marked REQUIRED.
# You can also put provider keys in ~/.synapse/synapse.json instead of here;
# synapse.json keys win over .env on a per-call basis.

# ============================================================
# --- LLM Providers — Major Cloud (US) ---
# ============================================================

# Google Gemini (primary brain — REQUIRED for memory/KG engine; free tier works)
# https://aistudio.google.com/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# Anthropic Claude
# https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# OpenAI GPT
# https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Groq (fast inference — also required for voice message transcription)
# https://console.groq.com/keys
GROQ_API_KEY=""

# OpenRouter (multi-provider gateway, has free models)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# Mistral AI
# https://console.mistral.ai/
MISTRAL_API_KEY=""

# xAI Grok
# https://console.x.ai/
XAI_API_KEY=""

# Cohere
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=""

# Together AI (note: litellm env var is TOGETHERAI_API_KEY, one word)
# https://api.together.ai/settings/api-keys
TOGETHERAI_API_KEY=""

# DeepSeek
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=""

# ============================================================
# --- LLM Providers — Chinese ---
# ============================================================

# MiniMax
MINIMAX_API_KEY=""

# Moonshot / Kimi
MOONSHOT_API_KEY=""

# Zhipu Z.AI (prefix is zai/, NOT zhipu/)
ZAI_API_KEY=""

# Volcano Engine / BytePlus
VOLCENGINE_API_KEY=""

# Baidu Qianfan (ERNIE) — uses two keys; litellm reads QIANFAN_AK + QIANFAN_SK
QIANFAN_AK=""
QIANFAN_SK=""

# ============================================================
# --- LLM Providers — Self-Hosted / Special ---
# ============================================================

# HuggingFace Inference Endpoints
HUGGINGFACE_API_KEY=""

# NVIDIA NIM
# https://build.nvidia.com/
NVIDIA_NIM_API_KEY=""

# AWS Bedrock (no api_key — uses AWS credentials)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION_NAME="us-east-1"

# Google Vertex AI (no api_key — uses GCP Application Default Credentials or a
# service-account JSON file). The credentials file lives at:
#   POSIX:   ~/.config/gcloud/application_default_credentials.json
#   Windows: %APPDATA%\gcloud\application_default_credentials.json
# or export a path to a service-account JSON you downloaded from the GCP console.
VERTEXAI_PROJECT=""
VERTEXAI_LOCATION="us-central1"
# Optional — point this at a service-account JSON if you're not using gcloud ADC.
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"

# GitHub Copilot — NO env var. The wizard uses an OAuth device flow and writes
# the token to ~/.config/litellm/github_copilot/api-key.json. litellm auto-refreshes.

# Ollama / vLLM — no API key required. Configure api_base in synapse.json instead.

# ============================================================
# --- Infrastructure Config ---
# ============================================================
# (OPTIONAL) IP address of the local PC running Ollama inference (The Vault)
# If you leave this blank, the system runs entirely on cloud providers.
WINDOWS_PC_IP=""

# ============================================================
# --- Security & Webhooks ---
# ============================================================
# WhatsApp Bridge authorization secret
WHATSAPP_BRIDGE_TOKEN="your_whatsapp_bridge_secret"

# Gateway WebSocket authentication (optional)
# SYNAPSE_GATEWAY_TOKEN=

# ============================================================
# --- User Identity ---
# ============================================================
# Your phone number (E.164 format, e.g. +15551234567) — used for admin-level access
ADMIN_PHONE=""
# Optional: VIP user phone number (gets elevated access to tools like Gmail/Calendar)
VIP_PHONE=""

# ============================================================
# --- Operational Settings ---
# ============================================================
# Default session type for memory routing ("safe" or "spicy")
SESSION_TYPE="safe"
