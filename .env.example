# Synapse — minimal environment file
# Copy to .env and fill in the one required key. Everything else is optional.
#
# REQUIRED for the default chat path:
GEMINI_API_KEY=""

# Optional — Synapse will work without these but more chat roles unlock if set:
# OPENROUTER_API_KEY=""   # gives access to many models incl. free-tier
# ANTHROPIC_API_KEY=""    # claude routes
# GROQ_API_KEY=""         # voice transcription (whisper-large-v3)

# Gateway auth — strongly recommended in any non-localhost deploy:
# SYNAPSE_GATEWAY_TOKEN=""

# WhatsApp bridge (only if you pair the WA channel):
# WHATSAPP_BRIDGE_TOKEN=""

# See .env.example.advanced for the full reference (12 providers, all flags).
