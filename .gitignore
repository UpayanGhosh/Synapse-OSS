.env
.env.*
!.env.example

# OAuth / credential files
workspace/skills/gog/client_secret.json
workspace/skills/gog/token.pickle

# ──────────────────────────────────────────────────────────────
# Data files (runtime-generated, binary, or large)
# ──────────────────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.db-journal
workspace/db/
workspace/qdrant/
qdrant/storage/

# Log files
*.log
logs/
workspace/*.log

# Archive / backup
*.bak
*.gz
*.dat
*.mmap
db/backups/
_archived_memories/
REDUNDANCY_ARCHIVE_*/

# ──────────────────────────────────────────────────────────────
# JSON / text data files  (config templates are whitelisted below)
