{
  "_comment": "Copy this file to ~/.synapse/synapse.json and fill in the providers you actually plan to use. The onboarding wizard (python workspace/synapse_cli.py onboard) will populate this for you.",

  "providers": {
    "anthropic": {"api_key": "YOUR_ANTHROPIC_API_KEY"},
    "openai": {
      "api_key": "YOUR_OPENAI_API_KEY",
      "budget_usd": 10.0,
      "budget_duration": "monthly"
    },
    "gemini": {"api_key": "YOUR_GEMINI_API_KEY"},
    "groq": {"api_key": "YOUR_GROQ_API_KEY"},
    "openrouter": {"api_key": "YOUR_OPENROUTER_API_KEY"},
    "mistral": {"api_key": "YOUR_MISTRAL_API_KEY"},
    "togetherai": {"api_key": "YOUR_TOGETHER_AI_API_KEY"},
    "xai": {"api_key": "YOUR_XAI_API_KEY"},
    "cohere": {"api_key": "YOUR_COHERE_API_KEY"},
    "deepseek": {"api_key": "YOUR_DEEPSEEK_API_KEY"},

    "minimax": {"api_key": "YOUR_MINIMAX_API_KEY"},
    "moonshot": {"api_key": "YOUR_MOONSHOT_API_KEY"},
    "zai": {"api_key": "YOUR_ZAI_API_KEY"},
    "volcengine": {"api_key": "YOUR_VOLCENGINE_API_KEY"},
    "qianfan": {"api_key": "YOUR_QIANFAN_AK"},

    "huggingface": {"api_key": "YOUR_HF_API_KEY"},
    "nvidia_nim": {"api_key": "YOUR_NVIDIA_NIM_API_KEY"},

    "bedrock": {
      "aws_access_key_id": "YOUR_AWS_ACCESS_KEY_ID",
      "aws_secret_access_key": "YOUR_AWS_SECRET_ACCESS_KEY",
      "aws_region_name": "us-east-1"
    },

    "vertex_ai": {
      "project_id": "your-gcp-project-id",
      "location": "us-central1",
      "credentials_path": "/absolute/path/to/service-account.json"
    },

    "ollama": {
      "api_base": "http://localhost:11434"
    },
    "vllm": {
      "api_base": "http://localhost:8001/v1"
    }
  },

  "channels": {
    "telegram": {"token": "YOUR_TELEGRAM_BOT_TOKEN"},
    "discord": {
      "token": "YOUR_DISCORD_BOT_TOKEN",
      "allowed_channel_ids": []
    },
    "slack": {
      "bot_token": "xoxb-YOUR_BOT_TOKEN",
      "app_token": "xapp-YOUR_APP_TOKEN"
    },
    "whatsapp": {}
  },

  "model_mappings": {
    "casual": {
      "model": "gemini/gemini-2.0-flash",
      "fallback": "groq/llama-3.3-70b-versatile"
    },
    "code": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback": "openai/gpt-4o"
    },
    "analysis": {
      "model": "gemini/gemini-2.0-pro",
      "fallback": "anthropic/claude-sonnet-4-6"
    },
    "review": {
      "model": "anthropic/claude-opus-4-6",
      "fallback": "anthropic/claude-sonnet-4-6"
    },
    "vault": {
      "model": "ollama_chat/llama3.3",
      "fallback": null
    },
    "translate": {
      "model": "openrouter/meta-llama/llama-3.3-70b-instruct",
      "fallback": "groq/llama-3.3-70b-versatile"
    },
    "kg": {
      "model": "gemini/gemini-2.5-flash-lite",
      "fallback": "gemini/gemini-2.5-flash"
    }
  },

  "session": {
    "dual_cognition_enabled": true,
    "dual_cognition_timeout": 5.0
  },

  "embedding": {
    "provider": "auto",
    "model": null,
    "cache_dir": null,
    "threads": null
  },

  "vector_store": {
    "backend": "lancedb",
    "lancedb": { "db_path": null, "table_name": "memories" }
  },

  "kg_extraction": {
    "enabled": true,
    "min_messages": 15,
    "extract_interval_seconds": 1200,
    "kg_role": "kg"
  },

  "logging": {
    "level": "INFO",
    "format": "json",
    "modules": {
      "pipeline.chat": "INFO",
      "llm.router": "INFO",
      "channel.whatsapp": "INFO",
      "route.whatsapp": "INFO",
      "gateway.worker": "INFO",
      "dual_cognition": "INFO"
    }
  },
  "reconnect": {
    "_comment": "SUPV-02: WhatsApp bridge reconnect backoff. All timing in milliseconds.",
    "initialMs": 1000,
    "maxMs": 60000,
    "factor": 2.0,
    "jitter": 0.2,
    "maxAttempts": 5
  }
}
